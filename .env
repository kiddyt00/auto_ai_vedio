# 服务器配置
PORT=3002
HOST=localhost

# 数据库配置
MONGODB_URL=mongodb://localhost:27017/auto_ai_vedio

# AI模型配置
TEXT_MODEL=gpt-4
IMAGE_MODEL=stable-diffusion
VIDEO_MODEL=sora
AI_API_KEY=your-api-key-here

# 视频处理配置
VIDEO_OUTPUT_DIR=./output
VIDEO_MAX_DURATION=60
VIDEO_DEFAULT_RESOLUTION=1920x1080

# 安全配置
SECRET_KEY=your-secret-key-here
ALLOWED_ORIGINS=*